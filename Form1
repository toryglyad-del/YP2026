using System;
using System.Data.SqlClient;
using System.Drawing;
using System.Windows.Forms;

namespace Cosmetica1
{
    public partial class Form1 : Form
    {
        // ПОЛЯ ФОРМЫ (объявляем элементы)
        private TextBox txtLogin;
        private TextBox txtPass;
        private Button btnLogin;
        private Button btnGuest;
        private PictureBox logoBox;
        private Label lblLogin;
        private Label lblPass;

        // Строка подключения (ЗАМЕНИ НА СВОЮ, ЕСЛИ НУЖНО)
        string connectionString = @"Data Source=localhost\SQLEXPRESS;Initial Catalog=cosmetic;Integrated Security=True;TrustServerCertificate=True";

        public Form1()
        {
            // 1. Сначала инициализация компонентов (обязательно!)
            InitializeComponent();

            // 2. Настройка формы
            this.Text = "ООО Косметика";
            this.Size = new Size(400, 300);
            this.StartPosition = FormStartPosition.CenterScreen;

            // 3. Создаём элементы
            CreateControls();
        }

        private void CreateControls()
        {
            // Логотип
            PictureBox logo = new PictureBox
            {
                Image = Image.FromFile(@"Res\logo.png"), // название твоего файла
                Location = new Point(120, 20),      // положение (по центру)
                Size = new Size(150, 80),           // размер
                SizeMode = PictureBoxSizeMode.Zoom  // чтобы картинка вписалась
            };
            this.Controls.Add(logo);
            // Если есть картинка — раскомментируй:
            // logoBox.Image = Image.FromFile(@"logo.png");

            // Логин
            lblLogin = new Label
            {
                Text = "Логин:",
                Location = new Point(20, 120),
                Size = new Size(80, 20)
            };

            txtLogin = new TextBox
            {
                Location = new Point(110, 120),
                Size = new Size(200, 20)
            };

            // Пароль
            lblPass = new Label
            {
                Text = "Пароль:",
                Location = new Point(20, 150),
                Size = new Size(80, 20)
            };

            txtPass = new TextBox
            {
                Location = new Point(110, 150),
                Size = new Size(200, 20),
                PasswordChar = '*'
            };

            // Кнопка "Войти"
            btnLogin = new Button
            {
                Text = "Войти",
                Location = new Point(110, 190),
                Size = new Size(90, 30)
            };
            btnLogin.Click += BtnLogin_Click;

            // Кнопка "Гость"
            btnGuest = new Button
            {
                Text = "Войти как гость",
                Location = new Point(210, 190),
                Size = new Size(100, 30)
            };
            btnGuest.Click += BtnGuest_Click;

            // Добавляем ВСЕ элементы на форму
            this.Controls.Add(logoBox);
            this.Controls.Add(lblLogin);
            this.Controls.Add(txtLogin);
            this.Controls.Add(lblPass);
            this.Controls.Add(txtPass);
            this.Controls.Add(btnLogin);
            this.Controls.Add(btnGuest);
        }

        // Обработчик кнопки "Войти"
        private void BtnLogin_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrEmpty(txtLogin.Text) || string.IsNullOrEmpty(txtPass.Text))
            {
                MessageBox.Show("Введите логин и пароль", "Ошибка", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            using (SqlConnection conn = new SqlConnection(connectionString))
            {
                try
                {
                    conn.Open();
                    string query = "SELECT RoleId, Surname, Name, Patronymic FROM [User] WHERE Login = @log AND Password = @pass";
                    SqlCommand cmd = new SqlCommand(query, conn);
                    cmd.Parameters.AddWithValue("@log", txtLogin.Text);
                    cmd.Parameters.AddWithValue("@pass", txtPass.Text);

                    SqlDataReader reader = cmd.ExecuteReader();
                    if (reader.Read())
                    {
                        int roleId = reader.GetInt32(0);
                        string fio = $"{reader.GetString(1)} {reader.GetString(2)} {reader.GetString(3)}";

                        MessageBox.Show("Успешный вход!", "Успех", MessageBoxButtons.OK, MessageBoxIcon.Information);

                        Form2 mainForm = new Form2(roleId, fio);
                        mainForm.Show();
                        this.Hide();
                    }
                    else
                    {
                        MessageBox.Show("Неверный логин или пароль", "Ошибка", MessageBoxButtons.OK, MessageBoxIcon.Error);
                    }
                }
                catch (Exception ex)
                {
                    MessageBox.Show("Ошибка БД: " + ex.Message);
                }
            }
        }

        // Обработчик кнопки "Гость"
        private void BtnGuest_Click(object sender, EventArgs e)
        {
            Form2 guestForm = new Form2(3, "Гость"); // 3 - роль клиента
            guestForm.Show();
            this.Hide();
        }
    }
}
